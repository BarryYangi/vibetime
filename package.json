{
  "name": "vibetime",
  "version": "2026.5.12",
  "private": true,
  "description": "Local-first macOS time tracker for AI coding agents (Claude Code / Codex / Cursor / Gemini CLI).",
  "license": "MIT",
  "author": "Barry <barry@yct.ee>",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "NODE_OPTIONS=--experimental-require-module vitest run --project @vibetime/core --project @vibetime/desktop && pnpm --filter @vibetime/hook test",
    "depcheck": "depcruise --config .dependency-cruiser.cjs packages",
    "verify:core-zero-deps": "node -e \"const p=require('./packages/core/package.json');if(Object.keys(p.dependencies||{}).length){console.error('core must have empty dependencies');process.exit(1)}\"",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm depcheck && pnpm verify:core-zero-deps"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@biomejs/biome": "^2.4.13",
    "vitest": "^3.2.4",
    "dependency-cruiser": "^17.3.10",
    "@types/node": "^22"
  }
}
