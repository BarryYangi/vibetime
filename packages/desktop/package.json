{
  "name": "@vibetime/desktop",
  "productName": "VibeTime",
  "version": "2026.5.8",
  "private": true,
  "description": "Local-first macOS time tracker for AI coding agents.",
  "author": "Barry <barry@yct.ee>",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "pnpm run patch:electron-name && pnpm --filter @vibetime/hook build && pnpm run rebuild:native",
    "dev": "electron-vite dev",
    "generate:icons": "node scripts/generate-app-icon.mjs",
    "patch:electron-name": "node scripts/patch-electron-app-name.mjs",
    "prebuild": "pnpm --filter @vibetime/hook build",
    "build": "electron-vite build",
    "pack:mac": "pnpm run generate:icons && pnpm run build && electron-builder --mac --arm64 --dir",
    "dist:mac": "pnpm run generate:icons && pnpm run build && electron-builder --mac --arm64",
    "pack:win": "pnpm run generate:icons && pnpm run build && electron-builder --win --x64 --dir",
    "dist:win": "pnpm run generate:icons && pnpm run build && electron-builder --win --x64",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/sn-pro": "^5.2.6",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/colors": "^3.0.0",
    "@vibetime/core": "workspace:*",
    "@vibetime/hook": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "jotai": "^2.19.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
