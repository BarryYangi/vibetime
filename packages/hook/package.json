{
  "name": "@vibetime/hook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./config": "./dist/config.js",
    "./install": "./dist/install.js"
  },
  "scripts": {
    "test": "pnpm --filter @vibetime/core build && bun test src",
    "build": "pnpm --filter @vibetime/core build && pnpm run build:js && pnpm run build:bin",
    "build:js": "bun build src/index.ts src/cli.ts src/config.ts src/install.ts --outdir dist --target=node --format=esm --packages=external",
    "build:bin": "bun build --compile --minify --bytecode src/index.ts --outfile vibetime-hook"
  },
  "dependencies": {
    "@vibetime/core": "workspace:*",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^6.0.3"
  }
}
